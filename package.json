{
  "name": "freya-seo-next-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env CMS_PUBLIC_SOURCE=local next build",
    "start": "next start",
    "vinext:dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "vinext:build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "vinext:start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && npm run vinext:build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/ensure-mongodb-indexes.mjs",
    "db:migrate": "node scripts/ensure-mongodb-indexes.mjs",
    "db:migrate:dev": "node scripts/ensure-mongodb-indexes.mjs",
    "db:seed": "node scripts/seed-custom-cms.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@hookform/resolvers": "^5.4.0",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-table-cell": "^3.27.4",
    "@tiptap/extension-table-header": "^3.27.4",
    "@tiptap/extension-table-row": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.24.0",
    "mongodb": "^7.5.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "sanitize-html": "^2.17.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
